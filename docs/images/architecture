<svg viewBox="0 0 1000 800" xmlns="http://www.w3.org/2000/svg">
  <!-- Define gradients -->
  <defs>
    <linearGradient id="grad1" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#667eea;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#764ba2;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="grad2" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#f093fb;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#f5576c;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="grad3" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#4facfe;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#00f2fe;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="grad4" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#43e97b;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#38f9d7;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="grad5" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#fa709a;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#fee140;stop-opacity:1" />
    </linearGradient>
    
    <filter id="shadow" x="-50%" y="-50%" width="200%" height="200%">
      <feDropShadow dx="2" dy="4" stdDeviation="3" flood-opacity="0.3"/>
    </filter>
  </defs>

  <!-- Background -->
  <rect width="1000" height="800" fill="#f8f9fa"/>

  <!-- Title -->
  <text x="500" y="40" font-size="32" font-weight="bold" text-anchor="middle" fill="#1a202c">
    Portfolio Management API - Layered Architecture
  </text>

  <!-- CLIENT LAYER -->
  <g filter="url(#shadow)">
    <rect x="150" y="80" width="700" height="100" rx="10" fill="url(#grad1)" opacity="0.95"/>
    <text x="500" y="125" font-size="24" font-weight="bold" text-anchor="middle" fill="white">
      Client Application Layer
    </text>
    <text x="500" y="150" font-size="14" text-anchor="middle" fill="rgba(255,255,255,0.9)">
      Web Browsers | Mobile Apps | External Services
    </text>
  </g>

  <!-- Arrow 1 -->
  <g>
    <line x1="500" y1="180" x2="500" y2="220" stroke="#667eea" stroke-width="3"/>
    <polygon points="500,220 495,210 505,210" fill="#667eea"/>
    <text x="520" y="205" font-size="12" fill="#667eea" font-weight="bold">HTTP Request</text>
  </g>

  <!-- CONTROLLER LAYER -->
  <g filter="url(#shadow)">
    <rect x="150" y="220" width="700" height="120" rx="10" fill="url(#grad2)" opacity="0.95"/>
    <text x="500" y="265" font-size="22" font-weight="bold" text-anchor="middle" fill="white">
      Controller Layer
    </text>
    <text x="500" y="290" font-size="13" text-anchor="middle" fill="rgba(255,255,255,0.95)">
      @RestController | Request Routing | Input Validation
    </text>
    <rect x="170" y="295" width="140" height="35" rx="5" fill="rgba(255,255,255,0.2)" stroke="white" stroke-width="1.5"/>
    <text x="240" y="320" font-size="12" font-weight="bold" text-anchor="middle" fill="white">PortfolioController</text>
    
    <rect x="350" y="295" width="140" height="35" rx="5" fill="rgba(255,255,255,0.2)" stroke="white" stroke-width="1.5"/>
    <text x="420" y="320" font-size="12" font-weight="bold" text-anchor="middle" fill="white">AssetController</text>
    
    <rect x="530" y="295" width="160" height="35" rx="5" fill="rgba(255,255,255,0.2)" stroke="white" stroke-width="1.5"/>
    <text x="610" y="320" font-size="12" font-weight="bold" text-anchor="middle" fill="white">TransactionController</text>
  </g>

  <!-- Arrow 2 -->
  <g>
    <line x1="500" y1="340" x2="500" y2="380" stroke="#f5576c" stroke-width="3"/>
    <polygon points="500,380 495,370 505,370" fill="#f5576c"/>
    <text x="520" y="365" font-size="12" fill="#f5576c" font-weight="bold">Business Logic</text>
  </g>

  <!-- SERVICE LAYER -->
  <g filter="url(#shadow)">
    <rect x="150" y="380" width="700" height="120" rx="10" fill="url(#grad3)" opacity="0.95"/>
    <text x="500" y="425" font-size="22" font-weight="bold" text-anchor="middle" fill="white">
      Service Layer
    </text>
    <text x="500" y="450" font-size="13" text-anchor="middle" fill="rgba(255,255,255,0.95)">
      @Service | Business Logic | Data Transformation | Transaction Management
    </text>
    <rect x="170" y="455" width="140" height="35" rx="5" fill="rgba(255,255,255,0.2)" stroke="white" stroke-width="1.5"/>
    <text x="240" y="480" font-size="12" font-weight="bold" text-anchor="middle" fill="white">PortfolioService</text>
    
    <rect x="350" y="455" width="140" height="35" rx="5" fill="rgba(255,255,255,0.2)" stroke="white" stroke-width="1.5"/>
    <text x="420" y="480" font-size="12" font-weight="bold" text-anchor="middle" fill="white">AssetService</text>
    
    <rect x="530" y="455" width="160" height="35" rx="5" fill="rgba(255,255,255,0.2)" stroke="white" stroke-width="1.5"/>
    <text x="610" y="480" font-size="12" font-weight="bold" text-anchor="middle" fill="white">TransactionService</text>
  </g>

  <!-- Arrow 3 -->
  <g>
    <line x1="500" y1="500" x2="500" y2="540" stroke="#4facfe" stroke-width="3"/>
    <polygon points="500,540 495,530 505,530" fill="#4facfe"/>
    <text x="520" y="525" font-size="12" fill="#4facfe" font-weight="bold">Database Ops</text>
  </g>

  <!-- REPOSITORY LAYER -->
  <g filter="url(#shadow)">
    <rect x="150" y="540" width="700" height="120" rx="10" fill="url(#grad4)" opacity="0.95"/>
    <text x="500" y="585" font-size="22" font-weight="bold" text-anchor="middle" fill="white">
      Repository Layer
    </text>
    <text x="500" y="610" font-size="13" text-anchor="middle" fill="rgba(255,255,255,0.95)">
      @Repository | Spring Data JPA | CRUD Operations | Entity Mapping
    </text>
    <rect x="170" y="615" width="140" height="35" rx="5" fill="rgba(255,255,255,0.2)" stroke="white" stroke-width="1.5"/>
    <text x="240" y="640" font-size="12" font-weight="bold" text-anchor="middle" fill="white">PortfolioRepository</text>
    
    <rect x="350" y="615" width="140" height="35" rx="5" fill="rgba(255,255,255,0.2)" stroke="white" stroke-width="1.5"/>
    <text x="420" y="640" font-size="12" font-weight="bold" text-anchor="middle" fill="white">AssetRepository</text>
    
    <rect x="530" y="615" width="160" height="35" rx="5" fill="rgba(255,255,255,0.2)" stroke="white" stroke-width="1.5"/>
    <text x="610" y="640" font-size="12" font-weight="bold" text-anchor="middle" fill="white">TransactionRepository</text>
  </g>

  <!-- Arrow 4 -->
  <g>
    <line x1="500" y1="660" x2="500" y2="700" stroke="#38f9d7" stroke-width="3"/>
    <polygon points="500,700 495,690 505,690" fill="#38f9d7"/>
    <text x="520" y="685" font-size="12" fill="#38f9d7" font-weight="bold">ORM Mapping</text>
  </g>

  <!-- DATABASE LAYER -->
  <g filter="url(#shadow)">
    <rect x="150" y="700" width="700" height="80" rx="10" fill="url(#grad5)" opacity="0.95"/>
    <text x="500" y="735" font-size="22" font-weight="bold" text-anchor="middle" fill="white">
      MySQL Database
    </text>
    <text x="500" y="760" font-size="13" text-anchor="middle" fill="rgba(255,255,255,0.95)">
      Portfolio | Asset | Transaction Tables
    </text>
  </g>

  <!-- Side annotations -->
  <text x="50" y="130" font-size="11" fill="#666" font-weight="bold">Presentation</text>
  <text x="50" y="280" font-size="11" fill="#666" font-weight="bold">Interface</text>
  <text x="50" y="440" font-size="11" fill="#666" font-weight="bold">Business</text>
  <text x="50" y="600" font-size="11" fill="#666" font-weight="bold">Data Access</text>
  <text x="50" y="740" font-size="11" fill="#666" font-weight="bold">Persistence</text>

  <!-- Benefits box -->
  <rect x="50" y="50" width="80" height="20" rx="3" fill="none" stroke="#ccc" stroke-width="1" opacity="0"/>
</svg>